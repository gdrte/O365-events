# Local LLM via LM Studio (Server → Start Server in LM Studio, default port 1234)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
# Must match the model identifier shown in LM Studio's "Model" dropdown
AGENT_MODEL=gemma-4-e4b

# Anthropic (optional fallback — not used when LM Studio is active)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Kafka (K3S on Fedora)
KAFKA_BROKERS=192.168.0.103:9092
KAFKA_CLIENT_ID=triage-agent
KAFKA_GROUP_ID=triage-agent-group
KAFKA_INPUT_TOPIC=topic-false-positive
KAFKA_OUTPUT_TOPIC=topic-triage-verdict
KAFKA_SASL_ENABLED=false
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Microsoft Graph API (for live O365 user context checks)
# Register an app in Azure AD with: AuditLog.Read.All, User.Read.All, IdentityRiskyUser.Read.All
GRAPH_API_TOKEN=
# Or use client credentials flow:
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=

# Verification systems (configure endpoints for your environment)
# Endpoint/EDR API
EDR_API_URL=http://192.168.0.103:8080/api/endpoint
EDR_API_KEY=

# SIEM API (e.g., Elasticsearch/OpenSearch / Microsoft Sentinel)
SIEM_API_URL=http://192.168.0.103:9200
SIEM_API_KEY=

# Threat Intel (AbuseIPDB)
ABUSEIPDB_API_KEY=

# VirusTotal
VIRUSTOTAL_API_KEY=

# Agent settings
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_ITERATIONS=10
LOG_LEVEL=info
