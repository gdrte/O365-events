{
  "name": "triage-agent",
  "version": "1.0.0",
  "description": "LangChain AI triage agent for false-positive verification via Kafka",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsgo",
    "typecheck": "tsgo --noEmit ",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "demo": "ts-node --transpile-only src/demo.ts",
    "demo:scenario": "ts-node --transpile-only src/demo.ts",
    "monitor": "ts-node --transpile-only src/monitor.ts",
    "watch": "nodemon --exec 'ts-node --transpile-only src/index.ts'"
  },
  "dependencies": {
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "kafkajs": "^2.2.4",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260512.1",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
